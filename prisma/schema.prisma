generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── Users ────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // hashed
  name          String
  phone         String?
  avatar        String?
  role          String    @default("player") // player, venue_owner, admin
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings          BookingMember[]
  ownedVenues       Venue[]
  reviews           Review[]
  hostedTournaments Tournament[]
  tournamentTeams   TournamentTeam[]
  subscription      Subscription?
  points            PointsTransaction[]
}

// ─── Venues ───────────────────────────────────────────────
model Venue {
  id          String    @id @default(cuid())
  name        String
  description String?
  address     String
  city        String
  latitude    Float?
  longitude   Float?
  phone       String?
  email       String?
  website     String?
  images      String    @default("[]")  // JSON array of image URLs
  amenities   String    @default("[]")  // JSON array: parking, wifi, showers, changing_rooms, cafe, etc.
  sports      String    @default("[]")  // JSON array: futsal, basketball, badminton, tennis, cricket, etc.
  rating      Float     @default(0)
  totalReviews Int      @default(0)
  isOpen      Boolean   @default(true)
  isFeatured  Boolean   @default(false) // premium listing
  commission  Float     @default(8.0)   // platform commission %
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner         User          @relation(fields: [ownerId], references: [id])
  courts        Court[]
  reviews       Review[]
  tournaments   Tournament[]
  pricingRules  PricingRule[]
}

// ─── Courts / Playable Areas ─────────────────────────────
model Court {
  id          String   @id @default(cuid())
  name        String   // e.g. "Court A", "Pitch 1"
  sport       String   // futsal, basketball, badminton, etc.
  surface     String?  // artificial_turf, hardwood, clay, concrete
  isIndoor    Boolean  @default(false)
  pricePerHour Float   @default(0) // base price per hour
  venueId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue         Venue         @relation(fields: [venueId], references: [id])
  timeSlots     TimeSlot[]
  bookings      Booking[]
  pricingRules  PricingRule[]
}

// ─── Time Slots (Venue-defined availability) ────────────
model TimeSlot {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime String   // "09:00"
  endTime   String   // "10:00"
  price     Float?   // override court base price if set (flat, before PricingRule)
  isActive  Boolean  @default(true)
  courtId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  court     Court    @relation(fields: [courtId], references: [id])
}

// ─── Pricing Rules (Dynamic Pricing) ────────────────────
// Nepal venues have different rates for:
//   - Time of day (morning/evening premium vs day)
//   - Day of week (Saturdays, public holidays)
//   - Specific dates (Dashain, Tihar, events)
//
// Price resolution order:
//   1. PricingRule with flatPrice match  → use flatPrice
//   2. PricingRule with priceMultiplier  → (timeSlot.price || court.pricePerHour) × multiplier
//   3. TimeSlot.price                    → use if set
//   4. Court.pricePerHour                → base fallback
model PricingRule {
  id          String   @id @default(cuid())
  venueId     String
  courtId     String?  // null = applies to ALL courts in this venue

  name        String?  // "Saturday Premium", "Holiday Rate", "Morning Rush"

  // ── Trigger conditions ──
  // At least one must be set. Multiple conditions = AND (all must match).
  date        String?  // specific date "2025-10-20" (for holidays, events)
  dayOfWeek   Int?     // 0=Sun, 1=Mon, ..., 6=Sat
  startTime   String?  // time-of-day window start "06:00"
  endTime     String?  // time-of-day window end "09:00"

  // ── Rule validity period ──
  validFrom   String?  // rule active from date (inclusive)
  validUntil  String?  // rule active until date (inclusive)

  // ── Price effect (use ONE) ──
  flatPrice       Float?  // exact price per hour (overrides everything)
  priceMultiplier Float   @default(1.0) // multiply base price (e.g. 1.5 = 50% more)

  // ── Ordering ──
  priority    Int      @default(0) // higher = evaluated first
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue   Venue    @relation(fields: [venueId], references: [id])
  court   Court?   @relation(fields: [courtId], references: [id])
}

// ─── Bookings ────────────────────────────────────────────
model Booking {
  id            String    @id @default(cuid())
  date          String    // "2025-01-15" format
  startTime     String    // "09:00"
  endTime       String    // "10:00"
  status        String    @default("pending") // pending, confirmed, rejected, cancelled, completed
  totalPrice    Float     // price shown to / paid by customer
  effectivePrice Float    // actual price after dynamic pricing rules
  platformFee   Float     // commission amount
  notes         String?

  // ── Walk-in support ──
  isWalkIn      Boolean   @default(false) // true = owner entered manually (walk-in)

  // ── Confirmation flow ──
  confirmedBy   String?   // userId of who confirmed (owner/admin)
  confirmedAt   DateTime? // when confirmed
  rejectedBy    String?   // userId of who rejected
  rejectedAt    DateTime? // when rejected
  rejectionReason String? // why rejected

  // ── Cancellation flow ──
  cancelledBy   String?   // userId of who cancelled
  cancelledAt   DateTime? // when cancelled
  cancellationReason String? // why cancelled

  courtId       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  court         Court     @relation(fields: [courtId], references: [id])
  members       BookingMember[]
  payments      Payment[]

  @@index([status])
  @@index([courtId, date])
  @@index([isWalkIn])
}

// ─── Booking Members (for split payments) ───────────────
model BookingMember {
  id        String   @id @default(cuid())
  userId    String
  bookingId String
  amount    Float
  status    String   @default("pending") // pending, paid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  booking   Booking  @relation(fields: [bookingId], references: [id])
}

// ─── Payments ────────────────────────────────────────────
model Payment {
  id            String    @id @default(cuid())
  bookingId     String
  amount        Float
  method        String    @default("cash") // card, cash, wallet — default cash for Nepal (pay-at-venue)
  status        String    @default("pending") // pending, completed, failed, refunded
  transactionId String?   // external payment gateway reference
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  booking       Booking   @relation(fields: [bookingId], references: [id])
}

// ─── Tournaments ─────────────────────────────────────────
model Tournament {
  id          String    @id @default(cuid())
  name        String
  description String?
  sport       String
  format      String    @default("knockout") // knockout, league, round_robin
  maxTeams    Int       @default(8)
  entryFee    Float     @default(0)
  prizePool   Float     @default(0)
  startDate   String
  endDate     String
  status      String    @default("registration") // registration, ongoing, completed, cancelled
  venueId     String
  hostId      String
  image       String?
  rules       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  venue       Venue     @relation(fields: [venueId], references: [id])
  host        User      @relation(fields: [hostId], references: [id])
  teams       TournamentTeam[]
  matches     TournamentMatch[]
}

// ─── Tournament Teams ────────────────────────────────────
model TournamentTeam {
  id           String   @id @default(cuid())
  name         String
  captainId    String
  tournamentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  captain      User     @relation(fields: [captainId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  matchesAsA   TournamentMatch[] @relation("MatchTeamA")
  matchesAsB   TournamentMatch[] @relation("MatchTeamB")
}

// ─── Tournament Matches ─────────────────────────────────
model TournamentMatch {
  id            String   @id @default(cuid())
  round         Int      @default(1)
  matchNumber   Int
  scheduledDate String
  scheduledTime String
  scoreA        Int?
  scoreB        Int?
  status        String   @default("scheduled") // scheduled, live, completed, cancelled
  tournamentId  String
  teamAId       String?
  teamBId       String?
  courtId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tournament    Tournament     @relation(fields: [tournamentId], references: [id])
  teamA         TournamentTeam? @relation("MatchTeamA", fields: [teamAId], references: [id])
  teamB         TournamentTeam? @relation("MatchTeamB", fields: [teamBId], references: [id])
}

// ─── Subscriptions (Venue Owner Plans) ─────────────────
// Manual payment model for Nepal market (no automated gateway).
// Owner pays offline → admin verifies → admin upgrades manually.
model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  tier            String    @default("free")        // free, pro, enterprise
  status          String    @default("active")      // active, trial, expired, cancelled

  // ── Trial period ──
  trialStartsAt   DateTime?                          // when trial began
  trialEndsAt     DateTime?                          // when trial ends

  // ── Manual payment tracking ──
  activatedAt       DateTime?                        // when they first paid (trial → paid)
  currentPeriodStart DateTime?                       // billing period start
  currentPeriodEnd   DateTime?                       // billing period end
  lastPaidAmount     Float?                           // amount of last payment
  lastPaidMethod     String?                          // cash, bank_transfer, esewa, khalti
  lastPaidAt         DateTime?                        // when last payment recorded
  notes              String?                          // admin notes

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([tier])
}

// ─── Audit Log (Action Tracking) ──────────────────────────
// Append-only log of significant platform actions.
// No penalties — just tracking for transparency.
model AuditLog {
  id          String   @id @default(cuid())
  entityType  String                     // booking, user, venue, subscription, pricing_rule
  entityId    String                     // the ID of the affected entity
  action      String                     // created, status_changed, updated, deleted, role_changed
  actorId     String                     // who performed the action (userId)
  actorRole   String?                    // player, venue_owner, admin
  oldValue    String?                    // JSON: key fields before change
  newValue    String?                    // JSON: key fields after change
  metadata    String    @default("{}")   // extra context: reason, IP, etc.
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ─── Red Flags (Suspicious Activity Alerts) ─────────────────
// Advisory-only — no automated penalties.
// Admin reviews and resolves manually.
model RedFlag {
  id              String    @id @default(cuid())
  entityType      String                       // user, venue
  entityId        String                       // the flagged entity
  flagType        String                       // rapid_cancellation, frequent_rejection, suspicious_pattern, price_manipulation
  severity        String    @default("low")    // low, medium, high
  description     String                       // human-readable description
  metadata        String?   @default("{}")    // JSON: { cancelCount: 5, period: "7d" }
  isResolved      Boolean   @default(false)
  resolvedBy      String?
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([entityType, entityId])
  @@index([flagType])
  @@index([isResolved])
}

// ─── Loyalty Points (Earn-Only) ──────────────────────────
// Players earn points on online bookings (not walk-in).
// Redemption is empty for now — points just accumulate.
// Future: catalog, referral bonuses, partner rewards.
model PointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  bookingId   String?  // null for admin-granted points
  points      Int      // positive = earned, negative = redeemed (future)
  type        String   // booking_completed, review_posted, referral_bonus, admin_grant, redeemed (future)
  description String   // human-readable: "Earned 10 points for completing booking #abc123"
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([bookingId])
}

// ─── Reviews ─────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  comment   String?
  userId    String
  venueId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  venue     Venue    @relation(fields: [venueId], references: [id])
}

// ─── Government Holidays (Nepal) ──────────────────────────
// Admin-managed list of public holidays for dynamic pricing.
model Holiday {
  id              String   @id @default(cuid())
  name            String   // "Dashain", "Tihar", "Democracy Day", etc.
  date            String   // "2025-10-20"
  type            String   @default("public") // public, religious, national
  isRecurring     Boolean  @default(false) // true = repeats every year (same month/day)
  recurringMonth  Int?     // 10 for October
  recurringDay    Int?     // 20 for 20th
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([date])
  @@index([isActive])
}
