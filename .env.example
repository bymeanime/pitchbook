# ── PitchBook Environment Variables ──
# Copy this file to .env.local and fill in your values.

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database?pgbouncer=true

# Auth
JWT_SECRET=your-random-32-byte-hex-string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Seed (required to enable /api/seed endpoints)
SEED_SECRET=your-secret-seed-key

# Clerk (optional — set both or leave empty to use custom auth only)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (optional — for direct Supabase features)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Test Accounts (after running /api/seed?secret=SEED_SECRET) ──
# Admin:       admin@pitchbook.com    / admin123
# Venue Owner: arena@pitchbook.com    / owner123
# Player:      raj.thapa@email.com    / player123
